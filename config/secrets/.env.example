# Copy to .env and fill in real values

# Spot
SPOT_API_KEY=replace_me
SPOT_API_SECRET=replace_me

# Futures
FUTURES_API_KEY=replace_me
FUTURES_API_SECRET=replace_me

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me

# API auth
SPOT_API_USERNAME=paper_admin
SPOT_API_PASSWORD=replace_me
SPOT_JWT_SECRET=replace_me_at_least_32_chars

FUTURES_API_USERNAME=futures_admin
FUTURES_API_PASSWORD=replace_me
FUTURES_JWT_SECRET=replace_me_at_least_32_chars

# Runtime selectors
SPOT_ENV=paper
SPOT_PAIR_MODE=dynamic
SPOT_STRATEGY=AdaptiveMetaStrategy

FUTURES_ENV=paper
FUTURES_PAIR_MODE=dynamic
FUTURES_STRATEGY=UniversalMACD_Futures
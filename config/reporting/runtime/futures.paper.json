{
  "schema_version": "1.0",
  "timezone": "Europe/Rome",
  "studio_name": "Studio Trading System",
  "reporting": {
    "include_markdown": true,
    "include_json": true,
    "max_top_winners": 3,
    "max_top_losers": 3,
    "include_strategy_health": true,
    "include_risk_events": true,
    "include_scanner_summary": true
  },
  "paths": {
    "scanner_report": "reports/scanner/latest_scan_futures_paper.json",
    "strategy_manifest": "strategies/registry/deployment_manifest.json",
    "risk_profile": "config/risk/runtime/futures.paper.json",
    "output_dir": "reports/operations/daily",
    "pnl_input": "data/tradesv3_futures.sqlite"
  },
  "market_type": "futures",
  "portfolio_scope": "studio_futures",
  "summary_defaults": {
    "benchmark_symbol": "BTC/USDT:USDT",
    "capital_allocated_usd": 1000,
    "cash_buffer_ratio": 0.45
  },
  "profile_name": "paper",
  "risk_posture": "simulation",
  "input_source": {
    "type": "sqlite",
    "db_path": "data/tradesv3_futures.sqlite",
    "equity_start": 1000,
    "unrealized_buffer": 0,
    "risk_events": []
  }
}

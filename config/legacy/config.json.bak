{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "dry_run": true,
  "dry_run_wallet": 1000,
  "cancel_open_orders_on_exit": true,
  "max_open_trades": 2,
  "stake_currency": "USDT",
  "stake_amount": 50,
  "tradable_balance_ratio": 0.8,
  "fiat_display_currency": "USD",
  "timeframe": "15m",
  "unfilledtimeout": {
    "entry": 10,
    "exit": 10,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },
  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },
  "exit_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },
  "exchange": {
    "name": "binance",
    "key": "REPLACE_WITH_EXCHANGE_KEY",
    "secret": "REPLACE_WITH_EXCHANGE_SECRET",
    "ccxt_config": {
      "enableRateLimit": true
    },
    "ccxt_async_config": {
      "enableRateLimit": true,
      "rateLimit": 250
    },
    "pair_whitelist": [
      "BTC/USDT",
      "ETH/USDT"
    ],
    "pair_blacklist": [
      ".*UP/USDT",
      ".*DOWN/USDT",
      ".*BULL/USDT",
      ".*BEAR/USDT"
    ]
  },
  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],
  "order_types": {
    "entry": "limit",
    "exit": "limit",
    "stoploss": "market",
    "stoploss_on_exchange": false
  },
  "order_time_in_force": {
    "entry": "GTC",
    "exit": "GTC"
  },
  "api_server": {
    "enabled": true,
    "listen_ip_address": "0.0.0.0",
    "listen_port": 8080,
    "verbosity": "error",
    "enable_openapi": false,
    "jwt_secret_key": "ba4021f762f84ebab7f011b43f405181e0e856d0047ce3c25e5e36d86c3b0faa",
    "CORS_origins": [],
    "username": "freqtrade",
    "password": "REPLACE_WITH_A_STRONG_PASSWORD"
  },
  "telegram": {
    "enabled": false,
    "token": "DISABLED",
    "chat_id": "DISABLED"
  },
  "internals": {
    "process_throttle_secs": 5
  }
}

{
  "global_defaults": {
    "require_provider_gate_passed": true,
    "require_no_blocking_anomaly": true,
    "require_no_active_cooldown": false,
    "default_trading_mode": "shadow_only"
  },
  "pair_overrides": {
    "BTC/USDT": {"approved_trading_mode": "paper_candidate", "blocked_trading_mode": "shadow_only"},
    "ETH/USDT": {"approved_trading_mode": "paper_candidate", "blocked_trading_mode": "technical_shadow"},
    "SOL/USDT": {"require_no_active_cooldown": true, "approved_trading_mode": "candidate_shadow", "blocked_trading_mode": "shadow_only"}
  }
}
